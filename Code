def split_multiple():
    # Use only the final interpolated files
    input_files = [os.path.basename(f) for f in final_cleaned_files]
    
    # Define the time ranges for each chunk
    time_ranges = [
        (285, 345),
        (405, 465),
        (645, 705),
        (1005, 1065),
        (1125, 1185),
        (1425, 1485)
    ]
    
    for input_file in input_files:
        input_path = os.path.join(output_folder, input_file)
        base_name = os.path.splitext(input_file)[0].replace('_artifact_removed_interpolated', '')
        
        print(f"Processing: {input_file}")
        
        # Process each time range
        for i, (start_value, end_value) in enumerate(time_ranges, 1):
            output_file = os.path.join(output_folder, f"{base_name}_tone{i}.txt")
            
            line_counter = 0
            started = False
            
            with open(input_path, 'r') as infile, open(output_file, 'w') as outfile:
                for line in infile:
                    if not line.strip():
                        continue
                        
                    try:
                        first_value = float(line.split()[0])
                    except (ValueError, IndexError):
                        continue
                    
                    if not started and first_value >= start_value:
                        started = True
                        print(f"Chunk {i}: Started at value: {first_value}")
                    
                    if started and first_value <= end_value:
                        outfile.write(line)
                        line_counter += 1
                    
                    if started and first_value > end_value:
                        print(f"Chunk {i}: Reached end value: {first_value}")
                        break
            
            print(f"Created: {output_file}")
            print(f"Processed {line_counter} lines from {start_value} to {end_value}")
            print("-" * 50)

# Run chunking only on files
